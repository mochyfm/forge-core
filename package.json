{
  "name": "@mochyfm/forge-core",
  "type": "module",
  "version": "0.1.0",
  "description": "Núcleo compartido para landings: layout, secciones, islas Preact, tema y animaciones (Astro + Tailwind v4).",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "src/layouts",
    "src/components",
    "src/styles",
    "src/config"
  ],
  "exports": {
    "./styles.css": "./src/styles/global.css",
    "./config": "./src/config/site.ts",
    "./layouts/Base.astro": "./src/layouts/Base.astro",
    "./components/layout/Header.astro": "./src/components/layout/Header.astro",
    "./components/layout/Footer.astro": "./src/components/layout/Footer.astro",
    "./components/sections/*": "./src/components/sections/*",
    "./components/islands/*": "./src/components/islands/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "peerDependencies": {
    "@astrojs/preact": "^5.1.5",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.7",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/preact": "^5.1.5",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.7",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.1"
  }
}
