---
const features = [
  {
    title: "Ultra ligero",
    body: "Astro envía 0 KB de JS por defecto. Solo las islas cargan cliente.",
  },
  {
    title: "Islas Preact",
    body: "Interactividad puntual (menús, carruseles, formularios) con client:visible.",
  },
  {
    title: "Listo para clonar",
    body: "Marca, nav y tema centralizados. Copia, edita la config y publica.",
  },
];
---

<section id="caracteristicas" class="border-t border-black/5 bg-neutral-50/60">
  <div class="mx-auto max-w-6xl px-4 py-20 sm:py-24">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Características</h2>
      <p class="mt-3 text-muted">
        Una sección reutilizable. Duplica el patrón para crear las tuyas.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, i) => (
          <article
            class={`reveal reveal-delay-${i + 1} rounded-xl border border-black/10 bg-white p-6 shadow-sm`}
          >
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold">{feature.title}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{feature.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
