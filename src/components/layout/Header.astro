---
import type { SiteConfig } from "../../config/site";
import MobileMenu from "../islands/MobileMenu.tsx";

interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-black/10 bg-white/80 backdrop-blur">
  <div class="relative mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href="/" class="text-lg font-extrabold tracking-tight text-ink">
      {site.name}
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-muted transition-colors hover:text-ink"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={site.cta.href}
        class="rounded-md bg-brand px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-dark"
      >
        {site.cta.label}
      </a>
    </nav>

    <MobileMenu
      client:load
      items={site.nav}
      ctaLabel={site.cta.label}
      ctaHref={site.cta.href}
    />
  </div>
</header>
