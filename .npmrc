# El scope @mochyfm se publica/instala desde GitHub Packages (registro npm privado).
@mochyfm:registry=https://npm.pkg.github.com
# Token con read:packages (instalar) o write:packages (publicar).
# Exporta GITHUB_TOKEN en tu entorno; NUNCA lo escribas aquí.
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
